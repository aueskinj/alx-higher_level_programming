#!/bin/bash
# ---- Constants ----
PYTHON_PATH="/path/to/your/python"  # Update with your Python path (if needed)

# ---- Main Execution ----
# Check if PYCODE is set
if [ -z "$PYCODE" ]; then
  echo "Error: PYCODE environment variable is not set. Please set it to your Python code."
  exit 1  # Exit with an error
fi

# 2. Create a temporary file
temp_file=$(mktemp)
echo "$PYCODE" > "$temp_file"

# 3. Run the Python code from the temporary file
$PYTHON_PATH/python "$temp_file"

# 4. Handle Python script's exit code
exit_status=$?
if [ $exit_status -eq 0 ]; then
  echo "Python script executed successfully."
else
  echo "Python script failed with an error (code $exit_status). See output for details."
fi

# 5. Clean up the temporary file
rm "$temp_file"
